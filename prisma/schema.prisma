// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model History {
  id               Int            @id @default(autoincrement())
  patientName      String
  date             DateTime       @default(now())
  
  // AI Analysis Results
  aiStatus         String?      
  aiSeverity       String?      
  aiRecommendation String?      @db.Text
  aiPrimaryWarning String?      @db.Text
  
  // A History entry holds multiple Prescriptions (the actual drugs/medications)
  prescriptions    Prescription[] 
  
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
}

model Prescription {
  id               Int            @id @default(autoincrement())
  name             String
  dosage           String
  frequency        String
  
  historyId        Int
  history          History        @relation(fields: [historyId], references: [id], onDelete: Cascade)
}
