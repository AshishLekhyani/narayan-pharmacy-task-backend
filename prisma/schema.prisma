// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model PrescriptionRecord {
  id                      Int                @id @default(autoincrement())
  patientName             String
  prescribedAt            DateTime           @default(now())
  analysisStatusLabel     String?
  analysisSeverityLevel   String?
  analysisRecommendation  String?            @db.Text
  analysisPrimaryWarning  String?            @db.Text
  analysisClinicalImpact  Json?
  analysisProcessedBy     String?
  items                   PrescriptionItem[]
  createdAt               DateTime           @default(now())
  updatedAt               DateTime           @updatedAt
}

model PrescriptionItem {
  id                   Int                 @id @default(autoincrement())
  medicationName       String
  dosage               String
  frequency            String
  prescriptionRecordId Int
  prescriptionRecord   PrescriptionRecord  @relation(fields: [prescriptionRecordId], references: [id], onDelete: Cascade)
}

/// Caches Claude AI interaction results keyed by a canonical sorted drug fingerprint.
/// Prevents duplicate API calls for the same drug combination.
model AnalysisCache {
  id          Int      @id @default(autoincrement())
  cacheKey    String   @unique  // canonical sorted fingerprint of medications
  result      Json              // raw parsed JSON returned from Claude
  hitCount    Int      @default(1) // how many times this cache entry has been served
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
