PORT=5000
# Neon PostgreSQL — use sslmode=verify-full for pg v8+ compatibility
DATABASE_URL=postgresql://USER:PASSWORD@HOST/neondb?sslmode=verify-full
# Browser origin allowed by CORS (your deployed frontend URL in production)
FRONTEND_URL=http://localhost:3000
# Required for 2+ drug interaction checks (leave empty only for local non-AI testing)
ANTHROPIC_API_KEY=
# Optional — override if the default is unavailable on your Anthropic account
# Common alternatives: claude-sonnet-4-6 | claude-3-5-sonnet-20241022 | claude-haiku-4-5-20251001
ANTHROPIC_MODEL=claude-sonnet-4-6
NODE_ENV=development
